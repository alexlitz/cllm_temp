<mxfile host="app.diagrams.net">
  <diagram name="Zero Detector Vertical">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Inputs -->
        <mxCell id="a" value="a" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="280" y="20" width="80" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="b" value="b" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="420" y="20" width="80" height="50" as="geometry"/>
        </mxCell>

        <!-- Difference -->
        <mxCell id="diff" value="difference d = a − b" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="300" y="120" width="180" height="70" as="geometry"/>
        </mxCell>

        <!-- SiLU Node 1 -->
        <mxCell id="n1" value="SiLU&#xa;input: SCALE·d + SCALEε" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="80" y="260" width="220" height="80" as="geometry"/>
        </mxCell>

        <!-- SiLU Node 2 -->
        <mxCell id="n2" value="SiLU&#xa;input: SCALE·d" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="300" y="260" width="220" height="80" as="geometry"/>
        </mxCell>

        <!-- SiLU Node 3 -->
        <mxCell id="n3" value="SiLU&#xa;input: SCALE·d − SCALEε" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="520" y="260" width="220" height="80" as="geometry"/>
        </mxCell>

        <!-- Sum -->
        <mxCell id="sum" value="Σ" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="350" y="420" width="80" height="80" as="geometry"/>
        </mxCell>

        <!-- Output -->
        <mxCell id="out" value="Zero Indicator&#xa;≈1 if a ≈ b&#xa;≈0 otherwise" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="310" y="560" width="160" height="80" as="geometry"/>
        </mxCell>

        <!-- Edges -->
        <mxCell id="ea" edge="1" parent="1" source="a" target="diff" value="+1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="eb" edge="1" parent="1" source="b" target="diff" value="−1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="d1" edge="1" parent="1" source="diff" target="n1" value="SCALE">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="d2" edge="1" parent="1" source="diff" target="n2" value="SCALE">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="d3" edge="1" parent="1" source="diff" target="n3" value="SCALE">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="o1" edge="1" parent="1" source="n1" target="sum" value="+1/k">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="o2" edge="1" parent="1" source="n2" target="sum" value="−2/k">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="o3" edge="1" parent="1" source="n3" target="sum" value="+1/k">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="eout" edge="1" parent="1" source="sum" target="out">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>